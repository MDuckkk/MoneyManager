# ocr_service — environment variables (deploy defaults are CPU + keyless + stateless).
# Copy to .env for local runs; on PaaS set these in the dashboard.

# --- Device ---
PADDLE_DEVICE=cpu
TORCH_DEVICE=cpu
SURYA_QUANT=int8            # dynamic INT8 for Surya (CPU-only speedup)
FLAGS_use_mkldnn=0
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
PADDLE_TEXT_DET=PP-OCRv5_mobile_det

# --- Surya intra-container service ---
SURYA_URL=http://127.0.0.1:8765
SURYA_PORT=8765

# --- Keyless: no Gemini/Vertex; classification uses keyword/regex fallback ---
OCR_ENABLE_POLICY=0

# --- /scan guard: audit = never block (best for retail receipts), strict = reject non-docs, off ---
OCR_SCAN_GUARD_MODE=audit

# --- Stateless: no internal SQLite/Postgres. Money Manager owns persistence.
#     Set a URL (e.g. postgresql://... or leave "sqlite") to re-enable /requests + /reviews.
OCR_DB_URL=

# --- Limits / hardening (optional) ---
OCR_MAX_UPLOAD_MB=50
OCR_MAX_PDF_PAGES=30
# OCR_API_KEY=change-me      # if set, callers must send header X-API-Key
# OCR_RATE_PER_MIN=60        # 0 = disabled

# --- Public port (Render/Fly/Railway usually inject PORT automatically) ---
# PORT=8000

# --- Model cache dir (mount a volume here to avoid re-downloading ~1.5 GB) ---
HF_HOME=/models/hf
